
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;700&display=swap');
  .header {
    width:100%; aspect-ratio:3/1;
    background:linear-gradient(135deg,#021A49 0%,#123D72 38%,#2D5C8E 72%,#5CAFB8 100%);
    position:relative; overflow:hidden; border-radius:4px;
  }
  .hgrid {
    position:absolute; inset:0;
    background-image:
      linear-gradient(rgba(244,245,247,0.04) 1px,transparent 1px),
      linear-gradient(90deg,rgba(244,245,247,0.04) 1px,transparent 1px);
    background-size:44px 44px;
  }
  .hvign {
    position:absolute; inset:0;
    background:radial-gradient(ellipse 80% 90% at 50% 50%,transparent 30%,rgba(2,26,73,0.4) 100%);
  }
  .hinner {
    position:relative; z-index:1; width:100%; height:100%;
    display:flex; align-items:center; padding:0 5%; gap:4%;
  }
  .hc { position:absolute; width:16px; height:16px; z-index:2; }
  .hc.tl { top:8px; left:8px; border-top:1.5px solid rgba(244,245,247,0.3); border-left:1.5px solid rgba(244,245,247,0.3); }
  .hc.tr { top:8px; right:8px; border-top:1.5px solid rgba(244,245,247,0.3); border-right:1.5px solid rgba(244,245,247,0.3); }
  .hc.bl { bottom:8px; left:8px; border-bottom:1.5px solid rgba(244,245,247,0.3); border-left:1.5px solid rgba(244,245,247,0.3); }
  .hc.br { bottom:8px; right:8px; border-bottom:1.5px solid rgba(244,245,247,0.3); border-right:1.5px solid rgba(244,245,247,0.3); }
  .live {
    position:absolute; top:10px; right:14px; z-index:3;
    display:flex; align-items:center; gap:5px;
    background:rgba(26,107,60,0.18); border:1px solid rgba(26,107,60,0.5);
    padding:3px 10px;
  }
  .ld { width:5px; height:5px; border-radius:50%; background:#1A6B3C; animation:blink 2.2s ease-in-out infinite; }
  .lt { font-family:'JetBrains Mono',monospace; font-size:clamp(6px,1vw,9px); letter-spacing:.22em; color:#1A6B3C; font-weight:700; }
  .hleft { display:flex; align-items:center; gap:clamp(8px,2vw,18px); flex-shrink:0; }
  .hname { font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(14px,3.8vw,36px); color:#F4F5F7; line-height:1; }
  .hsub  { font-family:'JetBrains Mono',monospace; font-size:clamp(5px,0.9vw,9px); letter-spacing:.2em; color:rgba(244,245,247,0.4); margin-top:.25em; }
  .hcenter { flex:1; display:flex; flex-direction:column; align-items:center; gap:.5em; }
  .htag  { font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:clamp(9px,2vw,18px); color:rgba(244,245,247,0.92); text-align:center; line-height:1.3; }
  .htsub { font-family:'JetBrains Mono',monospace; font-size:clamp(5px,0.85vw,8px); letter-spacing:.18em; color:rgba(92,175,184,0.7); text-align:center; }
  .hright { display:flex; flex-direction:column; gap:.5em; flex-shrink:0; }
  .feat { display:flex; align-items:center; gap:6px; }
  .fd { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
  .ft { font-family:'JetBrains Mono',monospace; font-size:clamp(5px,0.9vw,9px); letter-spacing:.1em; color:rgba(244,245,247,0.75); white-space:nowrap; }
  .fdiv { width:100%; height:1px; background:rgba(244,245,247,0.08); }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.15} }
  @keyframes p1 { 0%{opacity:0;transform:scale(.5)} 15%{opacity:.7} 70%{opacity:0;transform:scale(2)} 100%{opacity:0} }
  @keyframes p2 { 0%{opacity:0;transform:scale(.5)} 15%{opacity:.7} 70%{opacity:0;transform:scale(2)} 100%{opacity:0} }
  .pp1 { animation:p1 3s ease-out infinite; opacity:0; transform-origin:80px 40px; }
  .pp2 { animation:p2 3s ease-out infinite 1.3s; opacity:0; transform-origin:80px 40px; }
  .bd  { animation:blink 2.5s ease-in-out infinite; }
</style>

<div class="header">
  <div class="hgrid"></div>
  <div class="hvign"></div>
  <div class="hc tl"></div><div class="hc tr"></div>
  <div class="hc bl"></div><div class="hc br"></div>
  <div class="live"><div class="ld"></div><span class="lt">LIVE ON ARC</span></div>
  <div class="hinner">
    <div class="hleft">
      <svg style="flex-shrink:0;width:clamp(36px,8vw,76px);height:clamp(36px,8vw,76px);" viewBox="0 0 160 160" fill="none">
        <defs>
          <linearGradient id="ch" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#F4F5F7"/>
            <stop offset="35%" stop-color="#D8DCE2"/>
            <stop offset="65%" stop-color="#9BA3AD"/>
            <stop offset="100%" stop-color="#6B7480"/>
          </linearGradient>
        </defs>
        <circle cx="80" cy="40" r="9" fill="none" stroke="#1A6B3C" stroke-width="1.5" class="pp1"/>
        <circle cx="80" cy="40" r="9" fill="none" stroke="#1A6B3C" stroke-width="1.5" class="pp2"/>
        <path d="M26,148 Q36,82 72,36" stroke="url(#ch)" stroke-width="18" stroke-linecap="round" fill="none"/>
        <path d="M134,148 Q124,82 88,36" stroke="url(#ch)" stroke-width="18" stroke-linecap="round" fill="none"/>
        <rect x="62" y="88" width="36" height="36" transform="rotate(45 80 106)" fill="url(#ch)"/>
        <rect x="70" y="96" width="20" height="20" transform="rotate(45 80 106)" fill="#021A49"/>
        <circle cx="80" cy="106" r="5" fill="#1A6B3C" class="bd"/>
        <circle cx="80" cy="40" r="7" fill="#1A6B3C" class="bd"/>
      </svg>
      <div>
        <div class="hname">ArcSense</div>
        <div class="hsub">SIGNAL INTELLIGENCE · ARC NETWORK</div>
      </div>
    </div>
    <div class="hcenter">
      <div class="htag">Every block. Every failure.<br/>Every on-chain signal.</div>
      <div class="htsub">PAY-PER-QUERY · AUTONOMOUS AGENT · ARC TESTNET</div>
    </div>
    <div class="hright">
      <div class="feat"><div class="fd" style="background:#5CAFB8;"></div><span class="ft">Live block intelligence</span></div>
      <div class="fdiv"></div>
      <div class="feat"><div class="fd" style="background:#1A6B3C;"></div><span class="ft">Pay-per-query API</span></div>
      <div class="fdiv"></div>
      <div class="feat"><div class="fd" style="background:#F4F5F7;"></div><span class="ft">Autonomous agent</span></div>
      <div class="fdiv"></div>
      <div class="feat"><div class="fd" style="background:#5CAFB8;"></div><span class="ft">On-chain gate contract</span></div>
    </div>
  </div>
</div>
